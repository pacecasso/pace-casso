# Canonical URL for Open Graph / metadata (no trailing slash). Example: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Plausible analytics domain (e.g. pacecasso.com). Leave unset to disable.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Mapbox public token (Directions / Map Matching when not using the proxy). Copy to `.env.local`.
# Production: set on your host (e.g. Vercel). Never commit real tokens in source files.
# NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional: route Mapbox traffic through `/api/mapbox/*` using a server-side token (better for quotas/abuse).
# Set `MAPBOX_ACCESS_TOKEN` (secret) on the server. Falls back to `NEXT_PUBLIC_MAPBOX_TOKEN` if unset.
# NEXT_PUBLIC_MAPBOX_PROXY=1
# MAPBOX_ACCESS_TOKEN=

# Optional — footer social links on /create (omit to hide)
# NEXT_PUBLIC_SOCIAL_INSTAGRAM=https://instagram.com/yourhandle
# NEXT_PUBLIC_SOCIAL_X=https://x.com/yourhandle
# NEXT_PUBLIC_SOCIAL_GITHUB=https://github.com/yourorg
# Optional — @handle used in “Copy share text” on the final step (default: pacecasso)
# NEXT_PUBLIC_SOCIAL_X_HANDLE=pacecasso
