# Canonical URL for Open Graph / metadata (no trailing slash). Example: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Plausible analytics domain (e.g. pacecasso.com). Leave unset to disable.
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Mapbox public token (Directions API). Copy this file to `.env.local` and set the token for local dev.
# Production: set on your host (e.g. Vercel). Never commit real tokens in source files.
# NEXT_PUBLIC_MAPBOX_TOKEN=
